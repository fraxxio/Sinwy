{
	"name": "sinwy",
	"workspaces": [
		"Sinwy.*"
	],
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "bun run ./Sinwy.Backend/index.ts",
		"typecheck": "tsc --noEmit",
		"typecheck:watch": "tsc --noEmit --watch",
		"lint": "biome lint .",
		"lint:fix": "biome lint . --write",
		"format": "biome format .",
		"format:check": "biome format . --check",
		"check": "biome check .",
		"check:fix": "biome check . --write",
		"db:up": "docker compose -f ./Sinwy.Backend/docker-compose.yml up -d",
		"db:down": "docker compose -f ./Sinwy.Backend/docker-compose.yml down",
		"db:migrate": "cd Sinwy.Backend && bunx drizzle-kit migrate",
		"db:generate": "cd Sinwy.Backend && bunx drizzle-kit generate",
		"auth:schema:generate": "bunx --bun auth@latest generate --config Sinwy.Backend/modules/auth/auth.ts"
	},
	"dependencies": {
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15"
	},
	"peerDependencies": {
		"typescript": "6.0.3"
	}
}
